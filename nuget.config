<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Nexus internal feed: hosts OLS.Root.* identity packages. -->
    <add key="labacacia-nexus" value="https://nexus-lc01.starfield.com.au/repository/nuget-hosted/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="labacacia-nexus">
      <package pattern="OLS.Root.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <labacacia-nexus>
      <add key="Username" value="%NEXUS_USERNAME%" />
      <add key="ClearTextPassword" value="%NEXUS_PASSWORD%" />
      <add key="ValidAuthenticationTypes" value="basic" />
    </labacacia-nexus>
  </packageSourceCredentials>
</configuration>
