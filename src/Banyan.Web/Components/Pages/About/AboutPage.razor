@page "/about"
@attribute [Authorize]
@using Banyan.Core
@using System.Security.Claims
@inject WebOptions Opts
@inject LocalAgentIdentity LocalAgent
@inject SqliteMemoryStore Store
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>About — Banyan</PageTitle>

<Row Gutter="24">
    <AntDesign.Col Span="12">
        <Card Title="Node" Size="small" Style="margin-bottom: 16px;">
            <Descriptions Bordered Column="1" Size="@DescriptionsSize.Small">
                <DescriptionsItem Title="Edition">
                    <Tag Color="blue">Lite</Tag>
                </DescriptionsItem>
                <DescriptionsItem Title="Listen">@Opts.Urls</DescriptionsItem>
                <DescriptionsItem Title="Memory DB">@Opts.MemoryDbPath</DescriptionsItem>
                <DescriptionsItem Title="CA mode">
                    <Tag>@Opts.CaServerType.ToString().ToLowerInvariant()</Tag>
                </DescriptionsItem>
                <DescriptionsItem Title="Vec index">
                    <Tag Color="@(Store.VecEnabled ? "green" : "default")">
                        @(Store.VecEnabled ? "enabled" : "disabled")
                    </Tag>
                </DescriptionsItem>
            </Descriptions>
        </Card>

        @if (!string.IsNullOrEmpty(LocalAgent.Nid))
        {
            <Card Title="Local agent identity" Size="small">
                <Descriptions Bordered Column="1" Size="@DescriptionsSize.Small">
                    <DescriptionsItem Title="NID">
                        <Text Code Style="font-size: 11px; word-break: break-all;">@LocalAgent.Nid</Text>
                    </DescriptionsItem>
                </Descriptions>
            </Card>
        }
    </AntDesign.Col>

    <AntDesign.Col Span="12">
        <Card Title="Current session" Size="small">
            @if (_user is not null)
            {
                <Descriptions Bordered Column="1" Size="@DescriptionsSize.Small">
                    <DescriptionsItem Title="Username">@_user.Name</DescriptionsItem>
                    <DescriptionsItem Title="Roles">
                        @foreach (var role in _user.Roles)
                        {
                            <Tag Color="purple" Style="margin-right: 4px;">@role</Tag>
                        }
                    </DescriptionsItem>
                    @if (_user.ExpiresAt.HasValue)
                    {
                        <DescriptionsItem Title="Token expires">
                            @_user.ExpiresAt.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")
                        </DescriptionsItem>
                    }
                </Descriptions>
            }
        </Card>
    </AntDesign.Col>
</Row>

@code {
    private UserInfo? _user;

    private sealed record UserInfo(string Name, string[] Roles, DateTimeOffset? ExpiresAt);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var claims = auth.User;
        if (claims.Identity?.IsAuthenticated == true)
        {
            var name = claims.Identity.Name
                ?? claims.FindFirstValue("preferred_username")
                ?? claims.FindFirstValue(ClaimTypes.NameIdentifier)
                ?? "unknown";
            var roles = claims.Claims
                .Where(c => c.Type is ClaimTypes.Role or "role")
                .Select(c => c.Value)
                .ToArray();
            DateTimeOffset? exp = null;
            if (long.TryParse(claims.FindFirstValue("exp"), out var expSec))
                exp = DateTimeOffset.FromUnixTimeSeconds(expSec);
            _user = new UserInfo(name, roles, exp);
        }
    }
}
