<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <AssemblyName>Banyan.Web</AssemblyName>
    <RootNamespace>Banyan.Web</RootNamespace>
    <UserSecretsId>banyan-web-demo</UserSecretsId>

    <IsPackable>true</IsPackable>
    <PackageId>Banyan.Web</PackageId>
    <Description>Banyan Web — embedded admin/setup/login UI and HTTP surface for Banyan Lite hosts; ships wwwroot assets, OIDC discovery, JWT-gated admin routes, and external-CA trust hooks.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Banyan.Core/Banyan.Core.csproj" />
    <ProjectReference Include="../Banyan.Auth/Banyan.Auth.csproj" />
    <ProjectReference Include="../Banyan.Lite/Banyan.Lite.csproj" />
    <ProjectReference Include="../Banyan.Mcp/Banyan.Mcp.csproj" />
    <ProjectReference Include="../Banyan.Embedders/Banyan.Embedders.csproj" />
    <ProjectReference Include="../Banyan.Identity/Banyan.Identity.csproj" />
    <ProjectReference Include="../Banyan.Node.Auth/Banyan.Node.Auth.csproj" />
    <ProjectReference Include="../Banyan.Observability/Banyan.Observability.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="AntDesign" Version="0.20.*" />
    <PackageReference Include="Ivy.Hub.Client" Version="0.1.0-alpha.6" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.*" />
    <!-- DPAPI for at-rest protection of the auto-generated local CA passphrase (Windows). -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="10.*" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="1.3.*" />
  </ItemGroup>
  <ItemGroup>
    <!-- The Web SDK already includes wwwroot/** as Content; force CopyToOutput so wwwroot lands
         next to Banyan.Web.dll wherever it ships (CLI's bin/, publish dir, …). -->
    <Content Update="wwwroot/**" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
<ItemGroup>
    <!-- Pin transitive MessagePack above the vulnerable 3.0.x (GHSA-hv8m-jj95-wg3x / NU1903, #108). -->
    <PackageReference Include="MessagePack" Version="3.1.7" />
  </ItemGroup></Project>
