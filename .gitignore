*.db
*.db-shm
*.db-wal
*.pem
*.key
*.key.enc
.banyan/
~/.banyan/

# ── Local AI assistant / scratch state ──────────────────────────────────────
.claude/
log/
todo

# ── ML assets — these are fetched at runtime via `banyan embedder download` ─
*.onnx
vec0.so
vec0.dylib
vec0.dll
vocab.txt
sentencepiece.bpe.model
tokenizer.json

# ── Docker / Docker Compose ─────────────────────────────────────────────────
.env
.env.local

# ── OS junk ─────────────────────────────────────────────────────────────────
