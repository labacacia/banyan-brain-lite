{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://banyan.local/schemas/knowledge-pack-manifest.v1.json",
  "title": "Banyan Knowledge Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "name",
    "version",
    "created_at",
    "pack_type",
    "content_types",
    "target_scopes"
  ],
  "properties": {
    "schema_version": {
      "const": "banyan.pack.manifest.v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "pack_type": {
      "type": "string",
      "minLength": 1,
      "description": "Examples: knowledge, promotion, recommendation, commercial_context."
    },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_recall": {
          "type": "boolean",
          "default": true
        },
        "allow_export": {
          "type": "boolean",
          "default": false
        },
        "allow_finetune": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keyword": {
          "type": "boolean",
          "default": true
        },
        "vector": {
          "type": "boolean",
          "default": false
        },
        "graph": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Reserved for extension namespaces such as commercial, provenance, or publisher-specific metadata."
    }
  }
}
